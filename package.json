{
  "name": "hap-silly-404",
  "version": "1.0.0",
  "description": "Custom 404 page with serverless roast function — teaching project",
  "type": "module",
  "private": true,
  "scripts": {
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "secretlint": "secretlint \"**/*\"",
    "check": "npm run lint && npm run format:check && npm run secretlint",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.mjs": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{css,html,md,json,toml}": [
      "prettier --write"
    ],
    "**/*": [
      "secretlint"
    ]
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@secretlint/secretlint-rule-preset-recommend": "^11.7.1",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^10.0.0",
    "globals": "^16.0.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.0.0",
    "secretlint": "^11.7.1"
  }
}
